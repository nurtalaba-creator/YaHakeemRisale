[  
  {"turkish": "Merhaba", "kurdish": "Slav"},  
  {"turkish": "Nasılsınız?", "kurdish": "Tu çawa yî?"},  
  {"turkish": "Ben iyiyim", "kurdish": "Ez baş im"},  
  {"turkish": "Teşekkür ederim", "kurdish": "Spas"},  
  {"turkish": "Güle güle", "kurdish": "Bi xatirê te"},  
  {"turkish": "Bunlar benim arkadaşlarım", "kurdish": "Ev hevalên min in"},  
  {"turkish": "Hava bugün çok güzel", "kurdish": "Hava îro gelek baş e"},  
  {"turkish": "Kitap okumayı seviyorum", "kurdish": "Ez bîrêj çûnê xwendinê hez dikim"},  
  {"turkish": "Bu şehir çok büyüktür", "kurdish": "Ev bajêr gelek mezin e"},  
  {"turkish": "Yemek çok lezzetliydi", "kurdish": "Xwarin gelek xweş bû"},  
  {"turkish": "Benim adım Ahmet", "kurdish": "Navê min Ahmed e"},  
  {"turkish": "Kedim çok sevimli", "kurdish": "Pişikê min gelek şirin e"},  
  {"turkish": "Bugün pazar", "kurdish": "Îro yê şembê ye"},  
  {"turkish": "Hangi renkleri seversin?", "kurdish": "Tu kîjan reng dikevin?"},  
  {"turkish": "Seni özledim", "kurdish": "Ez hevaltek kiriya"},  
  {"turkish": "Çalışkan bir öğrenci olmalısınız", "kurdish": "Divê tu xwendekarê karîger bî"},  
  {"turkish": "Uyku zamanı", "kurdish": "Demê xewne"},  
  {"turkish": "Nerede buluşalım?", "kurdish": "Em li kû re hebîn?"},  
  {"turkish": "Yarın hava yağmurlu olacak", "kurdish": "Sibe hava baran dibe"},  
  {"turkish": "Kütüphanede ders çalışıyorum", "kurdish": "Ez li pirtûkxanê ders di xwendinê de me"},  
  {"turkish": "Hayat kısa, sanat uzun", "kurdish": "Jiyan kurt e, huner dirêj e"}  
]